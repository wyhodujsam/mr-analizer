<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Exclude JPA entities (mutable by design) -->
    <Match>
        <Package name="com.mranalizer.adapter.out.persistence.entity"/>
    </Match>

    <!-- Exclude GitHub DTOs (Jackson-populated, mutable) -->
    <Match>
        <Package name="com.mranalizer.adapter.out.provider.github.dto"/>
    </Match>

    <!-- Exclude Spring Boot generated main class -->
    <Match>
        <Class name="com.mranalizer.MrAnalizerApplication"/>
    </Match>

    <!-- CT_CONSTRUCTOR_THROW: validation in constructors (FetchCriteria, domain builders) is intentional -->
    <Match>
        <Bug pattern="CT_CONSTRUCTOR_THROW"/>
    </Match>

    <!-- DM_DEFAULT_ENCODING: ClaudeCliAdapter uses ProcessBuilder output — UTF-8 on all our platforms -->
    <Match>
        <Bug pattern="DM_DEFAULT_ENCODING"/>
        <Class name="com.mranalizer.adapter.out.llm.ClaudeCliAdapter"/>
    </Match>

    <!-- EI_EXPOSE_REP/REP2: Java records, Spring controller constructor injection,
         and DTOs intentionally store/return mutable objects. Global suppress. -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
